<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground – grumpy/tired slouching parrot.
  Safe zone: centre 72×72dp = coords 18..90 on the 108 viewport.
  All artwork kept within x:24–84, y:22–88.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ==================== BODY ==================== -->
    <!-- Big hunched teardrop body, slightly right-leaning like the reference -->
    <path
        android:fillColor="#3CB54A"
        android:pathData="
          M58,46
          C46,46 32,52 28,64
          C24,76 30,88 48,88
          C66,88 82,80 84,68
          C86,56 72,46 58,46 Z"/>

    <!-- Wing feather lines on body (right side, scruffy) -->
    <path
        android:strokeColor="#2A8C38"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M62,62 C66,60 70,62 72,66"/>
    <path
        android:strokeColor="#2A8C38"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M61,68 C65,66 69,68 71,72"/>
    <path
        android:strokeColor="#2A8C38"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M60,74 C64,72 67,74 69,78"/>

    <!-- ==================== HEAD ==================== -->
    <!-- Rounded head sitting on the body, centre-left -->
    <path
        android:fillColor="#3CB54A"
        android:pathData="
          M52,22
          C38,22 28,32 28,44
          C28,56 38,62 52,62
          C66,62 76,56 76,44
          C76,32 66,22 52,22 Z"/>

    <!-- ==================== CREST ==================== -->
    <!-- 3 short spiky tufts on top, all within safe zone -->
    <path
        android:fillColor="#2A8C38"
        android:pathData="M49,22 C47,16 45,15 46,19 C47,21 48,22 49,22 Z"/>
    <path
        android:fillColor="#3CB54A"
        android:pathData="M53,21 C52,15 50,13 51,18 C52,20 52,21 53,21 Z"/>
    <path
        android:fillColor="#2A8C38"
        android:pathData="M57,22 C59,16 61,15 60,19 C59,21 58,22 57,22 Z"/>

    <!-- ==================== BEAK ==================== -->
    <!-- Upper mandible: starts narrow at face (~x42,y46), sweeps left and
         curves DOWN to a sharp hook tip at ~(24,58). Classic parrot shape. -->
    <path
        android:fillColor="#E8821A"
        android:pathData="M42,44 C38,43 30,43 25,50 C22,55 24,60 27,61 C30,55 36,50 42,50 Z"/>
    <!-- Hook tip / underside of upper mandible curving to point -->
    <path
        android:fillColor="#D06A10"
        android:pathData="M25,50 C23,54 24,60 27,61 C26,57 25,53 25,50 Z"/>
    <!-- Lower mandible: small, tucked under, short -->
    <path
        android:fillColor="#C86010"
        android:pathData="M42,50 C38,50 32,52 29,56 C31,58 36,57 40,54 C41,52 42,50 42,50 Z"/>
    <!-- Ridge line along top of upper beak -->
    <path
        android:strokeColor="#F5A030"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M42,44 C36,43 28,46 24,52"/>

    <!-- ==================== EYE ==================== -->
    <!-- Shifted right so it doesn't sit on top of the beak base -->
    <!-- Eye white -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M62,34 C62,39.5 57.5,44 52,44 C46.5,44 42,39.5 42,34 C42,28.5 46.5,24 52,24 C57.5,24 62,28.5 62,34 Z"/>

    <!-- Iris -->
    <path
        android:fillColor="#5A3A1A"
        android:pathData="M60,34 C60,38.4 56.4,42 52,42 C47.6,42 44,38.4 44,34 C44,29.6 47.6,26 52,26 C56.4,26 60,29.6 60,34 Z"/>

    <!-- Pupil -->
    <path
        android:fillColor="#111111"
        android:pathData="M57,34 C57,37.3 54.8,40 52,40 C49.2,40 47,37.3 47,34 C47,30.7 49.2,28 52,28 C54.8,28 57,30.7 57,34 Z"/>

    <!-- Eye shine -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M50,30 C50,31.1 49.1,32 48,32 C46.9,32 46,31.1 46,30 C46,28.9 46.9,28 48,28 C49.1,28 50,28.9 50,30 Z"/>

    <!-- ==================== TIRED EYELID ==================== -->
    <!-- Heavy drooping upper eyelid over the repositioned eye -->
    <path
        android:fillColor="#3CB54A"
        android:pathData="M42,28 C44,24 48,22 52,22 C56,22 60,25 62,29 C60,27 56,26 52,26 C48,26 44,28 42,28 Z"/>
    <!-- Eyelid bottom edge — droops diagonally (left side lower = grumpy) -->
    <path
        android:strokeColor="#1A5C28"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M42,30 C46,27 56,27 62,30"/>
    <!-- Angled brow line above eye for grumpy scowl -->
    <path
        android:strokeColor="#1A5C28"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M44,25 L54,22"/>

    <!-- ==================== FEET ==================== -->
    <!-- Orange scaly feet at the bottom, within safe zone -->
    <!-- Left foot -->
    <path
        android:fillColor="#E8821A"
        android:pathData="M40,84 L36,90 L40,90 L42,86 L44,90 L48,90 L44,84 Z"/>
    <!-- Foot scales -->
    <path
        android:strokeColor="#C06010"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M38,84 L38,90 M42,84 L42,90"/>
    <!-- Right foot -->
    <path
        android:fillColor="#E8821A"
        android:pathData="M54,84 L50,90 L54,90 L56,86 L58,90 L62,90 L58,84 Z"/>
    <path
        android:strokeColor="#C06010"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M52,84 L52,90 M56,84 L56,90"/>

</vector>
